{
    "layer": "top", 
    "spacing": 4, 
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": [ "clock"],
    "modules-right": ["mpd", "idle_inhibitor", "temperature", "cpu", "memory", "network", "pulseaudio", "keyboard-state"],
    "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{name}"
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "´Çú",
            "unlocked": "´é£"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "´ïÆ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "mpd": {
        "format": "´Çü  {title} - {artist} {stateIcon} [{elapsedTime:%M:%S}/{totalTime:%M:%S}] {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}[{songPosition}/{queueLength}] [{volume}%]",
        "format-disconnected": "´Çü Disconnected",
        "format-stopped": "´Çü {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "´âä "
        },
        "random-icons": {
            "on": "´ü┤ "
        },
        "repeat-icons": {
            "on": "´Ç× "
        },
        "single-icons": {
            "on": "´Ç×1 "
        },
        "state-icons": {
            "paused": "´üî",
            "playing": "´üï"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)",
        "on-click": "mpc toggle",
        "on-click-right": "foot -a ncmpcpp ncmpcpp",
        "on-scroll-up": "mpc volume +2",
        "on-scroll-down": "mpc volume -2"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "¯®░",
            "deactivated": "¯½º"
        }
    }, 
    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:L%Y-%m-%d %I:%M <tt><small>%p</small></tt>}"
    },
    "cpu": {
        "format": "´ïø {usage}%"
    },
    "memory": {
        "format": "¯┐à {}%"
    },
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "format": "{temperatureF}┬░F"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ´ç½",
        "format-ethernet": "¯¢ä {ifname}",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-disconnected": "Disconnected ¯½É {ifname}"
    },
    "pulseaudio": {
        "scroll-step": 5,
	"format": "{icon} {volume}% {format_source}",
        "format-bluetooth": "´èö {icon} {volume}% {format_source}",
        "format-bluetooth-muted": "´Ü® ´èö {icon} {format_source}",
        "format-muted": "´Ü® {format_source}",
        "format-source": "´ä░ {volume}%",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "default": ["´Çª", "´Çº", "´Ç¿"]
        },
        "on-click": "pavucontrol",
        "on-click-right": "foot -a pw-top pw-top"
    },
    "sway/window": {
        "max-length": 50
    }
}

